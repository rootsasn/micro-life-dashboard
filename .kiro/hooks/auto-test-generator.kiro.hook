{
  "enabled": true,
  "name": "Auto Test Generator",
  "description": "Automatically generates or updates Vitest tests for JSX/JS files with edge cases",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "web-pwa/src/**/*.{jsx",
      "js}"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A file was just saved. If it's a component or hook (not a test file), generate or update its corresponding .test.jsx/.test.js file with comprehensive tests including: basic rendering, edge cases (empty lists, max limits), user interactions, offline mode scenarios, and error handling. Use Vitest and @testing-library/react. Place test file in same directory as source file."
  }
}