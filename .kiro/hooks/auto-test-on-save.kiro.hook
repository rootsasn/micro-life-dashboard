{
  "enabled": true,
  "name": "Auto Test on Save",
  "description": "Automatically runs tests when JavaScript/JSX files are saved in the web-pwa directory",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "web-pwa/src/**/*.{js",
      "jsx}"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd web-pwa && npm run test"
  }
}